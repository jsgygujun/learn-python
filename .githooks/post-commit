#!/usr/bin/env bash
#
# post-commit hook - 自动检查 README.md 是否需要更新
#
# 检查逻辑：
# 1. 检测是否有新的 Python 模块文件（src/*.py）添加到 git
# 2. 检测是否有新的测试文件（tests/*.py）添加到 git
# 3. 检测是否有 pyproject.toml 的依赖变更
# 4. 如果以上任一条件满足，提示用户更新 README.md

set -e

# 获取本次提交新增的文件
ADDED_FILES=$(git diff-tree --no-commit-id --name-only --diff-filter=A -r HEAD 2>/dev/null || true)

# 检查是否需要更新 README
NEED_UPDATE=false
REASON=""

# 检查是否有新的 Python 源文件
NEW_SRC_FILES=$(echo "$ADDED_FILES" | grep -E '^src/.*\.py$' | grep -v '__init__\.py$' || true)
if [ -n "$NEW_SRC_FILES" ]; then
    NEED_UPDATE=true
    REASON="$REASON\n  - 新增源文件：$NEW_SRC_FILES"
fi

# 检查是否有新的测试文件
NEW_TEST_FILES=$(echo "$ADDED_FILES" | grep -E '^tests/.*\.py$' | grep -v '__init__\.py$' || true)
if [ -n "$NEW_TEST_FILES" ]; then
    NEED_UPDATE=true
    REASON="$REASON\n  - 新增测试文件：$NEW_TEST_FILES"
fi

# 检查 pyproject.toml 是否有依赖变更
if echo "$ADDED_FILES" | grep -q '^pyproject.toml$'; then
    NEED_UPDATE=true
    REASON="$REASON\n  - pyproject.toml 已更新（可能添加了新依赖）"
fi

# 如果需要更新，输出提示
if [ "$NEED_UPDATE" = true ]; then
    echo ""
    echo "========================================"
    echo "  README.md 更新提示"
    echo "========================================"
    echo "检测到以下变更，建议更新 README.md："
    echo -e "$REASON"
    echo ""
    echo "建议操作："
    echo "  1. 检查 README.md 的项目结构部分是否需要添加新文件"
    echo "  2. 检查技术栈是否有变化"
    echo "  3. 如有必要，运行：git add README.md && git commit --amend --no-edit"
    echo "========================================"
    echo ""
fi

exit 0
